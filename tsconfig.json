{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "js",
    "rootDir": "src",
    "sourceMap": true,
    "removeComments": false
  },
  "include": ["src/**/*.ts"]
}
